# Database URL is set by Coolify environment variables in production
# For local development, use: DATABASE_URL=file:./../db/custom.db
# For production (Coolify): DATABASE_URL=postgres://user:pass@host:5432/db

# NowPayments API Configuration
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_EMAIL=
NOWPAYMENTS_PASSWORD=
NOWPAYMENTS_BASE_URL=https://api.nowpayments.io/v1

# NowPayments Split Configuration
NOWPAYMENTS_SPLIT_PCT=10
NOWPAYMENTS_SPLIT_WALLET=

# JWT Secret (set by Coolify in production)
JWT_SECRET=

# App URL for webhook callbacks (set by Coolify in production)
NEXT_PUBLIC_APP_URL=
