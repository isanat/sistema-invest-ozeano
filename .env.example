# ============================================================================
# PLATAFORMA ROI - Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values
#
# IMPORTANT: For Vercel deployment, set DATABASE_URL in the Vercel dashboard
# under Settings > Environment Variables
#
# Recommended PostgreSQL providers:
# - Neon (https://neon.tech) - Free tier available
# - Supabase (https://supabase.com) - Free tier available
# - Railway (https://railway.app) - Free tier available
# ============================================================================

# Database - PostgreSQL connection string (REQUIRED for Vercel)
# Format: postgresql://user:password@host:5432/database?schema=public
DATABASE_URL=postgresql://user:password@host:5432/database?schema=public

# JWT Secret (REQUIRED in production - generate with: openssl rand -base64 32)
JWT_SECRET=

# NowPayments Configuration (Optional - configure via admin panel)
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_EMAIL=
NOWPAYMENTS_PASSWORD=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_2FA_SECRET=
NOWPAYMENTS_BASE_URL=https://api.nowpayments.io/v1
