# ============================================================================
# PLATAFORMA ROI - Ozeano Invest
# Environment Variables (REQUIRED in Vercel)
# ============================================================================

# Database URL - PostgreSQL (Neon) - pooled connection for serverless
DATABASE_URL=postgres://user:password@host:5432/database?sslmode=require
# Direct connection for migrations (optional)
DATABASE_URL_DIRECT=postgres://user:password@host:5432/database?sslmode=require

# ============================================================================
# NowPayments API Configuration (REQUIRED for deposits/withdrawals/splits)
# ============================================================================
# Get these from https://nowpayments.io/dashboard
NOWPAYMENTS_API_KEY=sua_api_key
NOWPAYMENTS_EMAIL=seu_email@nowpayments
NOWPAYMENTS_PASSWORD=sua_senha_nowpayments
NOWPAYMENTS_IPN_SECRET=seu_ipn_secret
NOWPAYMENTS_2FA_SECRET=seu_totp_secret
NOWPAYMENTS_BASE_URL=https://api.nowpayments.io/v1

# NowPayments Split Configuration (for automatic payment splits)
# Split percentage sent to platform wallet on each confirmed deposit
NOWPAYMENTS_SPLIT_PCT=10
# Platform wallet address (USDT TRC20) to receive split amounts
NOWPAYMENTS_SPLIT_WALLET=

# ============================================================================
# Security
# ============================================================================
# JWT Secret for session tokens (generate a strong random string)
JWT_SECRET=your_jwt_secret_here

# Cron secret for protecting scheduled endpoints
CRON_SECRET=your_cron_secret_here

# ============================================================================
# App Configuration
# ============================================================================
# Public URL for webhook callbacks (your Vercel deployment URL)
NEXT_PUBLIC_APP_URL=https://sistema-invest-ozeano.vercel.app
