# Database URL - PostgreSQL in production (Coolify)
DATABASE_URL=postgres://user:password@host:5432/database

# NowPayments API Configuration
NOWPAYMENTS_API_KEY=your_api_key_here
NOWPAYMENTS_IPN_SECRET=your_ipn_secret_here
NOWPAYMENTS_EMAIL=your_email@example.com
NOWPAYMENTS_PASSWORD=your_password_here
NOWPAYMENTS_BASE_URL=https://api.nowpayments.io/v1
NOWPAYMENTS_2FA_SECRET=your_2fa_secret_here

# NowPayments Split Configuration
NOWPAYMENTS_SPLIT_PCT=10
NOWPAYMENTS_SPLIT_WALLET=

# JWT Secret
JWT_SECRET=your_jwt_secret_here

# App URL for webhook callbacks
NEXT_PUBLIC_APP_URL=https://yourdomain.com
