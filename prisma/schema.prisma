// ============================================================================
// PLATAFORMA ROI - COPY TRADING ROI PLATFORM (SQLite)
// ============================================================================
// USDT primary currency. All financial values as String (precision-safe).
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  name          String
  walletAddress String?   // USDT wallet (TRC20)
  pixKey        String?   // PIX key for BRL
  role          String    @default("user") // user, admin
  isActive      Boolean   @default(true)

  // Balances (stored as string for precision, parsed as Decimal in app)
  balance            String   @default("0")       // USDT main balance
  affiliateBalance   String   @default("0")       // USDT affiliate commissions
  voucherBalance     String   @default("0")       // USDT voucher balance (from leader vouchers)
  totalRoi           String   @default("0")       // USDT total ROI earned
  totalInvested      String   @default("0")       // USDT total invested
  totalWithdrawn     String   @default("0")       // USDT total withdrawn
  teamBonusPct       String   @default("0")       // Team bonus % (0, 1, 2, or 3) based on affiliate rank

  // Affiliate fields
  affiliateCode          String?  @unique
  referredBy             String?
  referralLevel          Int      @default(1)
  totalAffiliateEarnings String   @default("0")
  hasInvested            Boolean  @default(false)
  linkUnlocked           Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  investments          Investment[]
  deposits             Deposit[]
  transactions         Transaction[]
  roiHistory           RoiHistory[]
  referredByUser       User?          @relation("Referrals", fields: [referredBy], references: [id])
  referrals            User[]         @relation("Referrals")
  affiliateCommissions AffiliateCommission[]
  affiliateWithdrawals AffiliateWithdrawal[]
  milestoneClaims      AffiliateMilestoneClaim[]
  badgeAwards          AffiliateBadgeAward[]
  adminLogs            AdminLog[]     @relation("AdminActions")
  nowpaymentsSubAccount NowPaymentsSubAccount?
  nowpaymentsDeposits   NowPaymentsDeposit[]
  nowpaymentsPayouts    NowPaymentsPayout[]
  vouchers             Voucher[]

  @@index([email])
  @@index([affiliateCode])
  @@index([referredBy])
  @@index([role])
}

model InvestmentPlan {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?

  minAmount    String   // Minimum investment in USDT, e.g. "10"
  maxAmount    String?  // Maximum investment in USDT, null = unlimited
  dailyRoiPct  String   // Daily ROI percentage, e.g. "5"
  durationDays Int      // Investment duration in days, e.g. 40 for doubling

  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  investments Investment[]

  @@index([isActive])
}

model Investment {
  id       String  @id @default(cuid())
  userId   String
  planId   String?

  amount      String  // Invested amount in USDT
  dailyRoi    String  // Daily ROI amount in USDT
  dailyRoiPct String  // ROI percentage
  totalRoi    String  // Total expected ROI

  startDate DateTime
  endDate   DateTime
  status    String  @default("active") // active, completed, cancelled

  teamBonusPct String @default("0") // Team bonus % from affiliate rank

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  plan           InvestmentPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)
  roiHistory     RoiHistory[]
  voucherUsages  VoucherUsage[]

  @@index([userId])
  @@index([status])
  @@index([userId, status])
}

model RoiHistory {
  id            String   @id @default(cuid())
  userId        String
  investmentId  String
  date          DateTime

  roiAmount String  // ROI paid in USDT
  roiPct    String  // Percentage applied
  teamBonus String  @default("0") // Team bonus from rank
  totalRoi  String  // Total paid that day including bonus

  createdAt DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Restrict)
  investment Investment @relation(fields: [investmentId], references: [id], onDelete: Cascade)

  @@unique([investmentId, date])
  @@index([userId])
  @@index([date])
  @@index([investmentId])
  @@index([investmentId, date])
}

model Deposit {
  id      String  @id @default(cuid())
  userId  String

  // All values in USDT
  amount    String  // USDT amount
  brlAmount String? // BRL equivalent (for PIX)
  usdtRate  String? // USDT/BRL rate at time

  type        String  // deposit, withdrawal
  method      String  // pix, usdt_trc20, usdt_polygon
  network     String? // TRC20, Polygon
  status      String  @default("pending") // pending, confirmed, cancelled, rejected
  txHash      String? // Blockchain tx hash (unique for USDT)
  pixTxId     String? // PIX transaction ID
  destination String? // Wallet address or PIX key for withdrawal
  description String?
  adminNotes  String?
  processedBy String?
  processedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([userId, status])
  @@unique([txHash])
}

model Transaction {
  id       String  @id @default(cuid())
  userId   String
  type     String  // deposit, withdrawal, roi_profit, investment, affiliate_commission, admin_adjust
  amount   String  // USDT amount
  brlAmount String? // BRL equivalent
  usdtRate  String? // Rate used
  status   String  @default("completed") // pending, completed, failed
  description String
  referenceId  String? // Related entity ID
  referenceType String? // Investment, Deposit, etc.
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@index([userId, type])
}

model AffiliateCommission {
  id          String  @id @default(cuid())
  userId      String  // Who receives
  fromUserId  String  // Who generated
  level       Int     // 1-11
  investmentId String?

  baseAmount       String // Base value in USDT
  percentage       String // Commission %
  commissionAmount String // Commission in USDT

  status  String  @default("pending") // pending, paid, cancelled
  createdAt DateTime @default(now())
  paidAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([fromUserId])
  @@index([status])
}

model AffiliateWithdrawal {
  id       String  @id @default(cuid())
  userId   String

  amount    String  // USDT requested
  fee       String  // Fee in USDT
  netAmount String  // Net in USDT
  method    String  // pix, usdt_trc20
  address   String? // USDT address
  pixKey    String? // PIX key
  status    String  @default("pending") // pending, approved, processing, completed, rejected
  adminNotes String?
  processedBy String?
  processedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([status])
}

// Default 11-level Unilevel: L1=10%, L2=4%, L3=3%, L4=2%, L5=1.5%, L6=1%, L7=0.8%, L8=0.5%, L9=0.4%, L10=0.3%, L11=0.5%
model AffiliateLevel {
  id          String  @id @default(cuid())
  level       Int     @unique // 1 to 11
  percentage  String  // Commission %
  description String?
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SystemConfig {
  id          String  @id @default(cuid())
  key         String  @unique
  value       String
  type        String  @default("string") // string, number, boolean, json
  description String?
  category    String  @default("general") // general, affiliate, withdrawal, trading, deposit
  isActive    Boolean @default(true)
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([key])
}

model AdminLog {
  id          String  @id @default(cuid())
  adminId     String?
  action      String  // create, update, delete, approve, reject
  entity      String  // user, plan, investment, config, deposit, withdrawal
  entityId    String?
  oldValue    String? // JSON
  newValue    String? // JSON
  description String
  ipAddress   String?
  createdAt   DateTime @default(now())

  admin User? @relation("AdminActions", fields: [adminId], references: [id], onDelete: SetNull)

  @@index([adminId])
  @@index([entity])
  @@index([createdAt])
}

// Team Bonus ranks: Bronze(+1% ROI), Prata(+2% ROI), Ouro(+3% ROI)
model AffiliateRank {
  id           String  @id @default(cuid())
  name         String  @unique // Bronze, Prata, Ouro
  icon         String  @default("🥉") // Emoji icon
  color        String  @default("#CD7F32") // Hex color
  minReferrals Int     @default(0) // Minimum direct referrals to qualify
  minEarnings  String  @default("0") // Minimum total affiliate earnings in USDT
  bonusAmount  String  @default("0") // One-time bonus when reaching this rank
  commissionBoost String @default("0") // Team bonus % daily ROI boost at this rank (1, 2, or 3)
  perks        String? // JSON array of perk descriptions
  sortOrder    Int     @default(0)
  isActive     Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([sortOrder])
  @@index([isActive])
}

model AffiliateMilestone {
  id          String  @id @default(cuid())
  name        String  // e.g. "First 5 Referrals"
  description String?
  targetCount Int     // Number of referrals needed
  rewardType  String  @default("cash") // cash, boost, badge
  rewardValue String  @default("0") // USDT amount for cash, % for boost
  icon        String  @default("🎯")
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([sortOrder])
  claims AffiliateMilestoneClaim[]
}

model AffiliateContest {
  id          String   @id @default(cuid())
  name        String   // e.g. "Summer Referral Challenge"
  description String?
  startDate   DateTime
  endDate     DateTime
  rewardPool  String   @default("0") // Total USDT reward pool
  metric      String   @default("referrals") // referrals, earnings, active_referrals
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([startDate])
}

model AffiliateMilestoneClaim {
  id          String @id @default(cuid())
  userId      String
  milestoneId String
  claimedAt   DateTime @default(now())

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestone AffiliateMilestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@unique([userId, milestoneId])
  @@index([userId])
}

model AffiliateBadge {
  id          String  @id @default(cuid())
  name        String  // e.g. "First Referral", "Top Recruiter"
  description String?
  icon        String  @default("🏅") // Emoji or icon class
  color       String  @default("#CD7F32") // Hex color for badge background
  category    String  @default("general") // general, recruitment, earnings, streak, special
  requirement String  // JSON describing how to earn: {"type":"referrals","count":1}
  rewardType  String  @default("none") // none, cash, boost
  rewardValue String  @default("0") // USDT amount or boost %
  isAuto      Boolean @default(true) // Auto-awarded when requirement met
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  awards AffiliateBadgeAward[]

  @@index([isActive])
  @@index([category])
  @@index([sortOrder])
}

model AffiliateBadgeAward {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge AffiliateBadge  @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@index([badgeId])
}

// ============================================================================
// NOWPAYMENTS INTEGRATION MODELS
// ============================================================================

model NowPaymentsSubAccount {
  id                 String  @id @default(cuid())
  userId             String  @unique  // Our internal user ID
  nowpaymentsUserId  String  @unique  // NowPayments sub-partner user_id
  depositAddressBtc  String? // BTC deposit address
  depositAddressUsdt String? // USDT TRC20 deposit address
  depositAddressUsdtPolygon String? // USDT Polygon deposit address
  isActive           Boolean @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([nowpaymentsUserId])
}

model NowPaymentsDeposit {
  id                String  @id @default(cuid())
  userId            String
  nowpaymentsPaymentId String? // NowPayments payment_id
  orderId           String? // Our internal order ID
  priceAmount       String  // Amount in USD/USDT
  priceCurrency     String  @default("usd")
  payAmount         String? // Crypto amount to pay
  payCurrency       String  @default("usdttrc20") // usdttrc20, btc, usdtmatic
  payAddress        String? // Generated deposit address
  paymentStatus     String  @default("waiting") // waiting, confirming, confirmed, sending, partially_paid, finished, failed, refunded, expired
  actuallyPaid      String? // Actual amount paid
  outcomeAmount     String? // Amount received after fees
  outcomeCurrency   String?
  
  // Split tracking
  splitProcessed    Boolean @default(false) // Whether the split was processed
  splitAmount       String  @default("0") // Amount sent to platform wallet
  splitPct          String  @default("0") // Split percentage used
  
  // Deposit relation
  depositId         String? // Link to our Deposit record
  
  purchaseId        String? // NowPayments purchase_id
  expiresAt         DateTime?
  confirmedAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([paymentStatus])
  @@index([nowpaymentsPaymentId])
  @@index([orderId])
}

model NowPaymentsPayout {
  id                    String  @id @default(cuid())
  userId                String
  nowpaymentsBatchId    String? // NowPayments batch_withdrawal_id
  nowpaymentsWithdrawalId String? // Individual withdrawal ID
  amount                String  // Amount in crypto
  currency              String  @default("usdttrc20") // usdttrc20, btc, trx
  destinationAddress    String  // User's wallet address
  payoutStatus          String  @default("CREATED") // CREATED, WAITING, PROCESSING, SENDING, FINISHED, FAILED, REJECTED
  verificationCode      String? // 2FA code
  verifiedAt            DateTime?
  payoutDescription     String?
  fee                   String  @default("0") // Network fee
  netAmount             String  @default("0") // Amount after fee
  txHash                String? // Blockchain tx hash
  
  // Deposit relation
  depositId             String? // Link to our Deposit record
  
  processedAt           DateTime?
  completedAt           DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([payoutStatus])
  @@index([nowpaymentsBatchId])
}

model NowPaymentsWebhookLog {
  id                String  @id @default(cuid())
  eventType         String  // payment_status_changed, payout_status_changed
  paymentId         String? // NowPayments payment_id
  payoutId          String? // NowPayments payout ID
  payload           String  // Full JSON payload
  signature         String? // x-nowpayments-sig header
  signatureValid    Boolean @default(false)
  processed         Boolean @default(false)
  processingError   String?
  createdAt         DateTime @default(now())

  @@index([eventType])
  @@index([paymentId])
  @@index([processed])
  @@index([createdAt])
}

// ============================================================================
// VOUCHER SYSTEM MODELS
// ============================================================================

model Voucher {
  id          String   @id @default(cuid())
  userId      String   // Leader who receives the voucher
  
  // Voucher details
  amount      String   // Total voucher amount in USDT
  usedAmount  String   @default("0") // Amount already used in rentals/purchases
  type        String   @default("custom") // basic, premium, custom
  
  // Status
  status      String   @default("active") // active, expired, revoked, completed
  
  // Goals (defaults for Basic=500, Premium=2000, but admin can customize)
  goalDirectReferrals   Int      @default(5)    // Min direct referrals needed
  goalMinReferralInvest String   @default("100") // Each referral must invest at least this USDT
  goalNetworkMultiple   String   @default("3")   // Total network investment must be this × voucher amount
  goalDays              Int      @default(30)     // Days to complete goals
  
  // Progress tracking (updated by cron/API)
  currentDirectReferrals   Int      @default(0)
  currentNetworkInvestment String   @default("0")  // Total network investment by referrals
  qualifyingReferrals      Int      @default(0)    // Referrals that meet min investment
  
  // Gradual withdrawal unlock (percentage 0-100)
  withdrawalUnlockPct String   @default("0") // How much of regular balance is unlocked for withdrawal
  
  // Dates
  deadline      DateTime  // When the voucher expires if goals not met
  completedAt   DateTime? // When all goals were met
  lastProgressUpdate DateTime? // Last time progress was recalculated
  
  // Admin tracking
  createdBy     String?   // Admin user ID who created
  revokedBy     String?   // Admin user ID who revoked
  revokeReason  String?   // Reason for revocation
  extendedDays  Int       @default(0) // Extra days added by admin
  adminNotes    String?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  usages        VoucherUsage[]
  
  @@index([userId])
  @@index([status])
  @@index([userId, status])
}

model VoucherUsage {
  id            String   @id @default(cuid())
  voucherId     String
  investmentId  String
  amount        String   // Amount used from voucher for this investment
  
  createdAt     DateTime @default(now())
  
  voucher       Voucher      @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  investment    Investment   @relation(fields: [investmentId], references: [id], onDelete: Cascade)
  
  @@index([voucherId])
  @@index([investmentId])
}

// ============================================================================
// COPY TRADING MODELS
// ============================================================================

model CopyTrader {
  id          String   @id @default(cuid())
  name        String
  avatar      String?
  specialty   String   @default("DeFi")
  winRate     String   @default("87")
  totalPnl    String   @default("0")
  monthlyRoi  String   @default("150")
  riskLevel   String   @default("medium")
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
}

model TradingPool {
  id          String   @id @default(cuid())
  name        String
  totalAum    String   @default("0")
  dailyVolume String   @default("0")
  strategy    String   @default("arbitrage")
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
